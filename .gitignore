# ==============================================
# Git忽略文件配置
# 提交代码前确认：所有敏感信息、临时文件、大文件都已经被忽略
# ==============================================

# ------------------------------
# 运行输出/日志/报告
# ------------------------------
/output/                 # 所有运行输出、分析报告、临时文件
/reports/                # 测试报告目录
*.xml                    # 不要提交output.xml等测试日志
*.html                   # 不要提交Robot生成的log.html/report.html
*.log                    # 运行日志文件
ai_analyzer*.log         # 分析器日志
/data/

# ------------------------------
# 敏感配置
# ------------------------------
ai_analyzer/config/config.yaml  # 包含API Key、密码等敏感配置，提交前记得备份到本地
.env                     # 环境变量文件
*.key                    # 密钥文件
*.pem                    # 私钥文件
passwords.txt            # 密码记录文件

# ------------------------------
# Python相关
# ------------------------------
__pycache__/             # Python缓存目录
*.pyc                    # 编译后的字节码
*.pyo                    # 优化后的字节码
*.pyd                    # Windows动态链接库
.pytest_cache/           # pytest缓存
.coverage                # 覆盖率报告
.tox/                    # tox测试环境
venv/                    # 虚拟环境目录
env/                     # 其他虚拟环境目录
*.egg-info/              # 打包缓存
dist/                    # 打包产物
build/                   # 构建目录

# ------------------------------
# IDE/编辑器相关
# ------------------------------
.vscode/                 # VSCode配置
.idea/                   # JetBrains系列IDE配置
*.swp                    # Vim临时文件
*.swo                    # Vim临时文件
*~                       # 备份文件
.DS_Store                # MacOS目录属性文件
Thumbs.db                # Windows缩略图缓存

# ------------------------------
# 临时/测试文件
# ------------------------------
*.tmp                    # 临时文件
*.temp                   # 临时文件
test_*.py                # 测试脚本（如果需要提交请手动添加）
debug_*.md               # 调试用报告
local_*                  # 本地测试文件

# ------------------------------
# 大文件
# ------------------------------
*.zip                    # 压缩包
*.rar                    # 压缩包
*.7z                     # 压缩包
*.tar.gz                 # 压缩包
*.pdf                    # 大文档
*.exe                    # 可执行文件
